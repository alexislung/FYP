# Easy Job — copy this file to ".env" next to server.py / database.py and fill in values.
# Never commit the real ".env" file.

# -----------------------------------------------------------------------------
# Flask / DeepSeek (server-side ONLY — browser never sees this)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=

# Optional comma-separated origins for browser API calls (e.g. https://yourdomain.com)
ALLOWED_ORIGINS=http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL / Supabase (server-side DATABASE_URL — keep secret)
# -----------------------------------------------------------------------------
DATABASE_URL=
# Example: postgres://USER:PASSWORD@HOST:5432/postgres

DB_SSL_MODE=require

# If direct db.*.supabase.co fails (IPv6-only DNS), pooler region for auto-fallback (default ap-southeast-1):
# SUPABASE_POOLER_REGION=ap-southeast-1

# -----------------------------------------------------------------------------
# Supabase Auth (frontend needs URL + anon key; we serve them via /api/public/supabase
# so they are NOT stored in github source code.)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
